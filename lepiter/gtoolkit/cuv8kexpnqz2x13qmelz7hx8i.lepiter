				},
				"paragraphStyle" : {
					"__type" : "textStyle"
				},
				"string" : "# Prototyping"
			},
			{
				"__type" : "textSnippet",
				"children" : {
					"__type" : "snippets",
					"items" : [ ]
				},
				"createEmail" : {
